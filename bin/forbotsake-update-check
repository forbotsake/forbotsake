#!/usr/bin/env bash
# forbotsake-update-check — periodic version check.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — remote VERSION differs from local
#   (nothing)                       — up to date, snoozed, disabled, or check skipped
set -euo pipefail

FORBOTSAKE_DIR="${FORBOTSAKE_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${FORBOTSAKE_HOME:-$HOME/.forbotsake}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
VERSION_FILE="$FORBOTSAKE_DIR/VERSION"
REMOTE_URL="${FORBOTSAKE_REMOTE_URL:-https://raw.githubusercontent.com/forbotsake/forbotsake/main/VERSION}"

# Read local version
LOCAL="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || echo "0.0.0")"

# ─── Step 1: Check for just-upgraded marker ────────────────
if [ -f "$MARKER_FILE" ]; then
  OLD="$(cat "$MARKER_FILE" | tr -d '[:space:]')"
  rm -f "$MARKER_FILE"
  echo "JUST_UPGRADED $OLD $LOCAL"
  exit 0
fi

# ─── Step 2: Respect user settings ────────────────
# Check if update checks are disabled
if [ -f "$STATE_DIR/config.yaml" ]; then
  _UC=$(grep "^update_check:" "$STATE_DIR/config.yaml" 2>/dev/null | awk '{print $2}' || true)
  if [ "$_UC" = "false" ]; then
    exit 0
  fi
fi

# ─── Step 3: Check snooze ────────────────
check_snooze() {
  local ver="$1"
  if [ ! -f "$SNOOZE_FILE" ]; then return 1; fi
  local snoozed_ver snoozed_level snoozed_ts now elapsed ttl
  read -r snoozed_ver snoozed_level snoozed_ts < "$SNOOZE_FILE" 2>/dev/null || return 1
  [ "$snoozed_ver" != "$ver" ] && return 1
  # Validate timestamp is numeric
  case "$snoozed_ts" in *[!0-9]*) return 1 ;; esac
  [ -z "$snoozed_ts" ] && return 1
  now=$(date +%s)
  elapsed=$(( now - snoozed_ts ))
  case "$snoozed_level" in
    1) ttl=86400 ;;   # 24h
    2) ttl=172800 ;;  # 48h
    *) ttl=604800 ;;  # 1 week
  esac
  [ "$elapsed" -lt "$ttl" ] && return 0
  return 1
}

# ─── Step 4: Check cache (15 min TTL) ────────────────
CACHE_TTL=15
if [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  STALE=$(find "$CACHE_FILE" -mmin +$CACHE_TTL 2>/dev/null || true)
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_VER" = "$LOCAL" ]; then exit 0; fi
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_OLD" = "$LOCAL" ]; then
          CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
          if check_snooze "$CACHED_NEW"; then exit 0; fi
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

# ─── Step 5: Fetch remote version ────────────────
mkdir -p "$STATE_DIR"

REMOTE=""
REMOTE="$(curl -fsSL --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Validate: must look like a version number
if ! echo "$REMOTE" | grep -qE '^[0-9]+(\.[0-9]+)+$'; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

# Versions differ
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"
if check_snooze "$REMOTE"; then
  exit 0
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
